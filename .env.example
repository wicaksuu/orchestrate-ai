# SIGMA Environment Variables

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Workspace Root untuk Sandbox
WORKSPACE_ROOT=/workspace/sandbox

# Port Configuration
BACKEND_PORT=8000
FRONTEND_PORT=80

# LLM Provider
# Options: simulated, anthropic, openai, codex
LLM_PROVIDER=simulated
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
DEFAULT_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5.5
