# SIGMA Environment Variables

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# MariaDB Configuration
MARIADB_DATABASE=sigma
MARIADB_USER=sigma
MARIADB_PASSWORD=sigma_password
MARIADB_ROOT_PASSWORD=sigma_root_password
DATABASE_URL=mysql://sigma:sigma_password@mariadb:3306/sigma
SECRET_KEY=change-this-secret-key

# Workspace Root untuk Sandbox
WORKSPACE_ROOT=/workspace/sandbox

# Port Configuration
BACKEND_PORT=8000
FRONTEND_PORT=80

# LLM Provider
# Options: simulated, anthropic, openai, codex
LLM_PROVIDER=simulated
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
DEFAULT_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5.5
