# SIGMA Environment Variables

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# MariaDB Configuration
MARIADB_DATABASE=sigma
MARIADB_USER=sigma
MARIADB_PASSWORD=sigma_password
MARIADB_ROOT_PASSWORD=sigma_root_password
DATABASE_URL=mysql://sigma:sigma_password@mariadb:3306/sigma
SECRET_KEY=change-this-secret-key

# Workspace Root untuk Sandbox
WORKSPACE_ROOT=/workspace/sandbox

# External Project Mount — Mount path spesifik di host ke container
# Contoh: /Users/wicaksu/Documents/Project atau ./my-projects
# JANGAN mount seluruh /Users untuk keamanan!
EXTERNAL_PROJECT_MOUNT=./sandbox

# Port Configuration
BACKEND_PORT=8000
FRONTEND_PORT=80

# LLM Provider
# Options: anthropic, openai, codex, gemini
LLM_PROVIDER=gemini
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
DEFAULT_MODEL=gemini-flash-latest
OPENAI_MODEL=gpt-5.5

# Workflow Settings
MAX_REVISION_LOOPS=3
SANDBOX_TIMEOUT_SECONDS=120
